# Postgres
POSTGRES_DB=chatdb
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=your_secure_password_here

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-your-key-here

# Google Translate (optional, for translation feature)
# Option 1: Service account JSON file path or content
GOOGLE_APPLICATION_CREDENTIALS=
# Option 2: Simple API key
GOOGLE_TRANSLATE_API_KEY=

# CORS (comma-separated allowed origins)
# Default for Docker: http://localhost:18080
CORS_ORIGINS=http://localhost:18080

# nginx host port (default: 18080)
NGINX_PORT=18080
