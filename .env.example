# Postgres connection string for services running inside docker-compose
# Use this when your backend runs as a container in the same compose network (service name: "db")
PG_CONNECTION_STRING=postgres://postgres:postgres@db:5432/transcript_chat

# If you need to connect from the host machine (outside containers),
# expose Postgres in docker-compose by adding under the db service:
#   ports:
#     - "5432:5432"
# then use:
# PG_CONNECTION_STRING_HOST=postgres://postgres:postgres@localhost:5432/transcript_chat

# If your client requires disabling SSL for local/dev connections, append ?sslmode=disable
# e.g. postgres://postgres:postgres@db:5432/transcript_chat?sslmode=disable

POSTGRES_DB=transcript_chat
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
