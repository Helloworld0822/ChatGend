# Example environment variables for local development
# Copy this to .env and edit values as needed

# Node
NODE_ENV=development
PORT=3000

# Database (Postgres)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://chatuser:chatpass@localhost:5432/chatdb

# If you prefer split variables instead of a single DATABASE_URL, you can use:
# PG_USER=chatuser
# PG_PASSWORD=chatpass
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=chatdb
